{
  "name": "@elisym/eval",
  "version": "0.2.0",
  "description": "Eval harness for payment-enabled AI agents - deterministic assertions over traces and ledgers",
  "keywords": [
    "ai-agents",
    "benchmarks",
    "eval",
    "evaluation",
    "llm",
    "payments",
    "prompt-injection"
  ],
  "homepage": "https://github.com/elisymlabs/elisym-eval#readme",
  "bugs": "https://github.com/elisymlabs/elisym-eval/issues",
  "license": "MIT",
  "author": "elisym labs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elisymlabs/elisym-eval.git",
    "directory": "packages/eval"
  },
  "bin": {
    "elisym-eval": "./dist/cli.js"
  },
  "files": [
    "dist",
    "datasets/v0/payments-v0.jsonl",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./payments": {
      "import": {
        "types": "./dist/payments.d.ts",
        "default": "./dist/payments.js"
      },
      "require": {
        "types": "./dist/payments.d.cts",
        "default": "./dist/payments.cjs"
      }
    },
    "./judges/anthropic": {
      "import": {
        "types": "./dist/judges/anthropic.d.ts",
        "default": "./dist/judges/anthropic.js"
      },
      "require": {
        "types": "./dist/judges/anthropic.d.cts",
        "default": "./dist/judges/anthropic.cjs"
      }
    },
    "./judges/openai": {
      "import": {
        "types": "./dist/judges/openai.d.ts",
        "default": "./dist/judges/openai.js"
      },
      "require": {
        "types": "./dist/judges/openai.d.cts",
        "default": "./dist/judges/openai.cjs"
      }
    },
    "./judges/openai-compatible": {
      "import": {
        "types": "./dist/judges/openai-compatible.d.ts",
        "default": "./dist/judges/openai-compatible.js"
      },
      "require": {
        "types": "./dist/judges/openai-compatible.d.cts",
        "default": "./dist/judges/openai-compatible.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "dataset:check": "bun dist/cli.js compile datasets/v0/index.ts --out datasets/v0/payments-v0.jsonl --check && bun dist/cli.js validate datasets/v0/payments-v0.jsonl",
    "dev": "tsup --watch",
    "format:check": "oxfmt --check src/ tests/",
    "lint": "oxlint src/",
    "qa": "tsup && vitest run && tsc --noEmit && oxlint src/ && oxfmt --check src/ tests/",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "~13.1.0",
    "zod": "~3.25.0"
  },
  "devDependencies": {
    "@types/node": "~22.0.0",
    "tsup": "~8.4.0",
    "typescript": "~5.7.0",
    "vitest": "~3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
