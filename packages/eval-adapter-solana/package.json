{
  "name": "@elisym/eval-adapter-solana",
  "version": "0.1.1",
  "description": "Solana PaymentAdapter for @elisym/eval - run payment evals against the elisym Solana rail",
  "keywords": [
    "ai-agents",
    "elisym",
    "eval",
    "payments",
    "solana"
  ],
  "homepage": "https://github.com/elisymlabs/elisym-eval#readme",
  "bugs": "https://github.com/elisymlabs/elisym-eval/issues",
  "license": "MIT",
  "author": "elisym labs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elisymlabs/elisym-eval.git",
    "directory": "packages/eval-adapter-solana"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "dev": "tsup --watch",
    "format:check": "oxfmt --check src/ tests/",
    "lint": "oxlint src/",
    "qa": "tsup && vitest run && tsc --noEmit && oxlint src/ && oxfmt --check src/ tests/",
    "test": "vitest run",
    "test:live": "vitest run --config vitest.live.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elisym/eval": "~0.2.0",
    "@elisym/sdk": "~0.25.5",
    "@solana-program/memo": "~0.11.0",
    "@solana-program/system": "~0.12.0",
    "@solana-program/token": "~0.5.0",
    "@solana/kit": "~6.8.0",
    "decimal.js-light": "~2.5.0",
    "nostr-tools": "~2.23.0"
  },
  "devDependencies": {
    "@types/node": "~22.0.0",
    "tsup": "~8.4.0",
    "typescript": "~5.7.0",
    "vitest": "~3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
